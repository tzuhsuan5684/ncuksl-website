image: node:20-alpine

# 快取 node_modules 減少重複安裝時間
cache:
  paths:
    - node_modules/

stages:
  - deploy

# 只有 push 到 main 分支才會執行部署
pages:
  stage: deploy
  script:
    - npm install               # 安裝套件
    - npm run build             # 建置 React 專案 → 產生 dist/
    - cp dist/index.html dist/404.html  # 解決重新整理時 404 的問題
    - rm -rf public             # 移除原本的 public/ 避免 mv 變成子資料夾
    - mv dist public            # GitLab Pages 規定輸出資料夾必須叫 public/
  artifacts:
    paths:
      - public                  # GitLab 會把這個資料夾發布到 Pages
  rules:
    - if: $CI_COMMIT_BRANCH == "main"